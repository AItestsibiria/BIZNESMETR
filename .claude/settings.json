{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|mcp__github__delete_file|mcp__github__push_files|mcp__github__create_or_update_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-skills.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
