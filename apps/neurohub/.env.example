# MuziAi neurohub — шаблон .env
# Скопируй в /var/www/neurohub/.env, замени значения, chmod 600.
# Никогда НЕ коммить реальные значения в git.

# ==================== CORE ====================
NODE_ENV=production
PUBLIC_HOST=https://muziai.ru
DATABASE_URL=file:./data.db
SESSION_SECRET=                          # 32+ random bytes (base64 ok)
SIGNED_URL_SECRET=                       # 32+ random bytes для подписи stream URLs

# ==================== ОБЯЗАТЕЛЬНЫЙ (без него не работает генерация) ====================
GPTUNNEL_API_KEY=                        # https://gptunnel.ru → API Keys

# ==================== AUDIO (mic → STT → Suno) ====================
YANDEX_FOLDER_ID=                        # https://console.cloud.yandex.ru → Сервисный аккаунт
YANDEX_SPEECHKIT_API_KEY=                # API Key для SpeechKit
OPENAI_API_KEY=                          # https://platform.openai.com/api-keys (Whisper STT fallback)

# ==================== LLM (chatbot, агенты) ====================
ANTHROPIC_API_KEY=                       # https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY_BACKUP=                # резервный Claude key #2
ANTHROPIC_API_KEY_BOT=                   # резервный Claude key #3 (TG-бот)
LLM_PROVIDER=anthropic                   # anthropic | openai
LLM_MODEL=claude-sonnet-4-6              # см. CLAUDE.md для актуальных id

# TimeWeb AI Gateway — основной резерв после всех Anthropic ключей.
# OpenAI-compatible. URL auto-discovery если TIMEWEB_GATEWAY_URL пуст.
TIMEWEB_GATEWAY_KEY=                     # https://timeweb.cloud → AI Gateway
TIMEWEB_GATEWAY_URL=                     # опц. явный URL (gateway.timeweb.cloud/v1/chat/completions)
TIMEWEB_GATEWAY_MODEL=gpt-4o-mini        # модель по умолчанию для fallback'а

# ==================== EMAIL (SMTP через Gmail) ====================
GMAIL_USER=tissan2021@gmail.com          # ящик-отправитель
GMAIL_APP_PASSWORD=                      # https://myaccount.google.com/apppasswords (16 символов)

# Альтернативный SMTP (если не Gmail):
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MuziAi <noreply@muziai.ru>"

# ==================== TELEGRAM ====================
TELEGRAM_BOT_TOKEN=                      # @BotFather → /token
TELEGRAM_WEBHOOK_SECRET=                 # 16-32 alphanumeric (rand) — secret_token для setWebhook, проверяется header X-Telegram-Bot-Api-Secret-Token
ADMIN_TELEGRAM_ID=                       # @userinfobot → твой Chat ID (для alerts)
ADMIN_ALERT_EMAIL=egnovoselo@gmail.com   # на кого слать low-balance alerts

# ==================== ROBOKASSA (платежи) ====================
ROBO_MERCHANT_LOGIN=                     # https://partner.robokassa.ru → Технические настройки
ROBO_PASSWORD_1=                         # Sign password 1
ROBO_PASSWORD_2=                         # Sign password 2

# ==================== VK (опционально, channel + pixel) ====================
VK_GROUP_ID=
VK_ACCESS_TOKEN=
VK_CONFIRMATION_CODE=
VK_SECRET=
VK_PIXEL_ID=

# ==================== MAX MESSENGER (опционально) ====================
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=

# ==================== ANALYTICS (опционально) ====================
YM_COUNTER_ID=                           # Yandex.Metrika

# ==================== INFRA ====================
AUTHORS_DIR=/var/www/neurohub/authors    # путь до папки треков и обложек
UPLOADS_DIR=/var/www/neurohub/uploads    # путь до пользовательских аплоадов
CRON_SECRET=                             # секрет для admin/check-gptunnel-balance cron-вызовов
