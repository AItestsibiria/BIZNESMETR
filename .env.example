# --- Runtime ---
NODE_ENV=development
PORT=3000
PUBLIC_URL=https://bot.example.com

# --- Database (Postgres for internal state: users, history, facts) ---
DATABASE_URL=postgresql://biznesmetr:biznesmetr@localhost:5432/biznesmetr?schema=public
TEST_DATABASE_URL=postgresql://biznesmetr:biznesmetr@localhost:5432/biznesmetr_test?schema=public

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_HEAVY=claude-opus-4-7

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-random-string
TELEGRAM_WEBHOOK_PATH=/webhooks/telegram

# --- MAX (Sprint 2) ---
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_WEBHOOK_PATH=/webhooks/max

# --- Authorization ---
# Comma-separated Telegram user IDs allowed to talk to the bot.
# Find yours by messaging @userinfobot in Telegram.
ALLOWED_TELEGRAM_USER_IDS=
ALLOWED_MAX_USER_IDS=

# --- Google (Sheets, Calendar, Gmail) ---
# Path inside the container to the service-account JSON key.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-credentials.json
# The Sheets workbook id (from its URL).
HUB_SHEET_ID=
# Calendar id to use ("primary" or a specific calendar's id from Settings).
# Note: domain-wide delegation may be required for the service account to act
# on a personal calendar. For a dedicated work calendar shared with the
# service account email, "primary" of the SA itself is enough.
GOOGLE_CALENDAR_ID=primary
# Gmail: requires Workspace domain-wide delegation. The service account
# impersonates this user. Leave blank to disable Gmail tools.
GMAIL_USER_EMAIL=
# Default timezone for date parsing in tools.
DEFAULT_TZ=Europe/Moscow

# --- GitHub ---
# Personal access token (fine-grained or classic) with at least: repo, read:org.
# Required for github_* tools; leave blank to disable.
GITHUB_TOKEN=
# Optional org filter for "my PRs" / "my issues" queries.
GITHUB_OWNER=

# --- Daily digest ---
# Cron expression in DEFAULT_TZ. Empty disables the scheduler.
DIGEST_CRON=0 9 * * *
# Comma-separated chat ids that should receive the morning digest.
DIGEST_CHAT_IDS=

# --- Logging ---
LOG_LEVEL=info
